# 🐖 Custom .gitignore

# 🐖 Directories
sanctuary/sandbox/
**/node_modules/

# 🐖 Blender stuff
*.blend1

# 🐖 DEFAULT GODOT .gitignore
# Godot 4+ specific ignores
.godot/
.nomedia

# 🐖 Godot-specific ignores
.import/
export.cfg
export_credentials.cfg

# 🐖 Imported translations (automatically generated from CSV files)
*.translation

# 🐖 Mono-specific ignores
.mono/
data_*/
mono_crash.*.json

# 🐖 Python tooling
py-tools/.venv/
py-tools/__pycache__/

# 🐖 Obsidian ignore
# Ignore volatile UI-related state
.obsidian/workspace.json
.obsidian/app.json
.DS_Store
Thumbs.db
