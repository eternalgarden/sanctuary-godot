# ---------- Text Files (auto line endings) ----------
*.cs text eol=lf
*.cginc text eol=lf
*.shader text eol=lf
*.gd text eol=lf
*.gdshader text eol=lf
*.json text eol=lf
*.txt text eol=lf
*.md text eol=lf
*.xml text eol=lf
*.tres text eol=lf
*.tscn text eol=lf
*.cfg text eol=lf
*.conf text eol=lf

# ---------- Binary but DIFFABLE (use normal Git) ----------
*.res diff=godot-res
*.import diff=godot-import

# ---------- LFS - Large Binary Files ----------
# Images
*.png filter=lfs diff=lfs merge=lfs -text
*.jpg filter=lfs diff=lfs merge=lfs -text
*.jpeg filter=lfs diff=lfs merge=lfs -text
*.gif filter=lfs diff=lfs merge=lfs -text
*.tif filter=lfs diff=lfs merge=lfs -text
